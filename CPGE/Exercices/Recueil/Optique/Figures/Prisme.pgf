\draw [dashed] (14.225,3) --(13.725,2.125);
\draw (14.0583,2.7083) arc  (60:120:-9pt);
\draw (14.0583,2.7083) arc  (70:10:-10.5pt);
\draw (12.5,1.0375) rectangle (12.7,1.2375);
\draw (12.5,3) rectangle (12.7,3.2);
\draw (0,1.0375) rectangle (0.2,1.2375);
\draw (0,3) rectangle (0.2,3.2);



