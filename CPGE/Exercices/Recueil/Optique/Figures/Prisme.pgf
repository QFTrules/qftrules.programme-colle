\usetikzlibrary{patterns}
\usetikzlibrary{arrows}
\definecolor{cornellred}{rgb}{0.7, 0.11, 0.11}
\definecolor{indigo}{rgb}{0.0, 0.25, 0.42}


\begin{tikzpicture}
%Tubes
\draw (0,0) rectangle (12,4);
\draw (0,2) -- (12,2);
%\node (p1) at (6,3) {\huge $p_{1}$};
%\node (p2) at (6,1) {\huge $p_{2}$};
\node (n1) at (0.7,2.5) {\huge $n_{1}$};
