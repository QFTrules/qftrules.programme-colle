    \item \myURL{M3}{Exp.~\ThemeLetter{#2}#3.#4} : #5%
  \end{liste}%
}

\newcommand{\techTP}[4][]{%
  \ifthenelse{\equal{#1}{}}{}{\textsc{#1}}%
  \begin{liste}%
    \item \myURL{TP01}{#3} : #4%
  \end{liste}%
}

