\draw [thick,-stealth] (0,0) -- (4,0);
\draw (4,0) node [below] {\footnotesize$\omega$};

\draw [thick, color=bostonuniversityred,samples=500,domain=0:1] plot (\x,{2*2*\x*(1-\x/2)});

