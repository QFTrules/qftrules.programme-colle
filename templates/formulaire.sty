\tcbset{
common/.style={
fontupper=\citshape,
lower separated=false,
% before upper={\setlength{\parindent}{\normalparindent}},
coltitle=white,
colback=gray!5,
boxrule=0.5pt,
fonttitle=\bfseries,
enhanced,
breakable,
top=8pt,
before skip=8pt,
attach boxed title to top left={
yshift=-0.11in,
xshift=0.15in},
boxed title style={
boxrule=0pt,
colframe=white,
arc=0pt,
outer arc=0pt},
separator sign={.},},
defstyle/.style={
common,
colframe=main,
colback=main!1,
colbacktitle=main!70,
overlay unbroken and last={
\node[anchor=south east, outer sep=0pt] at (\linewidth-width,0) {
\textcolor{main}{
%$\clubsuit$
}};}},
thmstyle/.style={
common,
colframe=second,
colback=second!1,
colbacktitle=second!70,
overlay unbroken and last={
\node[anchor=south east, outer sep=0pt] at (\linewidth-width,0) {
\textcolor{second}{
%$\heartsuit$
}};}},
propstyle/.style={
common,
colframe=third,
colback=third!1,
colbacktitle=third!70,
overlay unbroken and last={
\node[anchor=south east, outer sep=0pt] at (\linewidth-width,0) {
\textcolor{third}{
%$\spadesuit$
}};}},
}
\tcbset{
  introductionsty/.style={
    enhanced,
    breakable,
    colback=structurecolor!10,
    colframe=structurecolor,
    fonttitle=\bfseries,
    colbacktitle=structurecolor,
    fontupper=\citshape,
    attach boxed title to top center={yshift=-3mm,yshifttext=-1mm},
    boxrule=0pt,
    toprule=0.5pt,
    bottomrule=0.5pt,
    top=8pt,
    before skip=8pt,
    sharp corners
  },
  }

% \newtcbtheorem[auto counter,number within=chapter]{definition}{\definitionname}{defstyle}{def}
\DeclareTColorBox[auto counter]{definition}{ o t\label g }{
common,defstyle,
IfValueTF={#1}{title={\definitionname~\formucounter.\thetcbcounter\ (#1)}}{title=\definitionname~\formucounter.\thetcbcounter},
IfBooleanTF={#2}{label=#3}{}}
% \newtcbtheorem[auto counter,number within=chapter]{theorem}{\theoremname}{thmstyle}{thm}
\DeclareTColorBox[auto counter]{theorem}{ o t\label g }{
common,thmstyle,
IfValueTF={#1}{title={\theoremname~\formucounter.\thetcbcounter\ (#1)}}{title=\theoremname~\formucounter.\thetcbcounter},
IfBooleanTF={#2}{label=#3}{}}
\DeclareTColorBox[auto counter]{prop}{ o t\label g }{
common,propstyle,
IfValueTF={#1}{title={\propname~\formucounter.\thetcbcounter\ (#1)}}{title=\propname~\formucounter.\thetcbcounter},
IfBooleanTF={#2}{label=#3}{}}
