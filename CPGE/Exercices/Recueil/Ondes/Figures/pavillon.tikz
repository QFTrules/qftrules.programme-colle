\begin{tikzpicture}
\draw plot [domain=0:3] (\x, {0.5 *exp(\x/3)});
\draw plot [domain=0:3] (\x, {-0.5*exp(\x/3)});
\draw[->,>=latex] (0,0) -- ++(3,0) node[right] {$x$};
\draw[<->,>=latex] (1,-{0.5 *exp(1/3)}) -- (1,{0.5 *exp(1/3)}) node[below right] {$S(x)$};
\draw[dashed] (0,0.5) -- ++(0,-1);
\draw[dashed] (3,{0.5*exp(1)}) -- ++(0,-{exp(1)});
