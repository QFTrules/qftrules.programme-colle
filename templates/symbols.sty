% boxed equation
\newcommand{\eqbox}[2][*]{
  \StrLen{#1}[\numberlength]
  \ifthenelse{\equal{\detokenize{#1}}{\detokenize{*}}}{
    % sans argument : non numéroté
    \begin{equation*}
    \boxed{#2}
    \end{equation*}
  }{
    \ifthenelse{\numberlength=0}{
      % avec argument vide : numéroté non étiquetté
    \begin{equation}
    \boxed{#2}
    \end{equation}
    }{
      % avec argument non vide : numéroté et étiquetté
      \begin{equation}
        \label{eq:#1}
        \boxed{#2}
      \end{equation}
    }
  }
}

% standard equation
\newcommand{\eq}[2][*]{
\begin{equation#1}
#2
\end{equation#1}
}

% system of equations
