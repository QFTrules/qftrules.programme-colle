\draw (1,-0.1) -- (1,0.1);
\draw (1,0) node [below] {\footnotesize$\omega_{0}$};

\draw (-0.1,2) -- (0.1,2);
\draw (0,2) node [left] {\footnotesize $P_{M}$};

