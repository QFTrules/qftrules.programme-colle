\newcommand{\tech}[5][]{%
  \ifthenelse{\equal{#1}{}}{}{\textsc{#1}}%
  % \def\CoursCode{M2}
  % \trim{\expandafter\ThemeLetter{#2}}#3
  % \ThemeLetter{#2}#3
