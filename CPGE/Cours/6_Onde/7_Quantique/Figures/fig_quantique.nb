Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Vreel", "[", "x_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "1"}], "/", "1000"}], "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"2", "*", "x"}], "]"}], "-", "1"}], ")"}], "^", "10"}]}]}], 
  ";"}]], "Input",
