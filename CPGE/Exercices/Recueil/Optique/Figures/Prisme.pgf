%\node (a) at (15,4.7) {\huge $a$};

%Lame semi-reflÃ©chissante
\draw[dotted,ultra thick] (12.5,2) -- (15.96,2);

%Rayons
\draw[->] (16.125,-0.25) -- (15.125,1.5);
\draw (15.125,1.5) -- (14.825,2);
%\draw [cornellred,thick,thick,thick] (15.125,1.5) -- (14.225,3) -- (0,3);
\draw [cornellred,thick] (14.825,2) -- (14.625,2.33);
\draw [cornellred,thick,<->] (14.625,2.33) -- (14.425,2.66);
\draw [cornellred,thick](14.425,2.66) -- (14.225,3) -- (0,3);
\draw [cornellred,thick,<->] (13,3) -- (13.5,3);
\draw [cornellred,thick,<->] (4,3) -- (8,3);
\draw [->] (14.825,2) -- (14.975,2.2625);
\draw (14.975,2.2625) -- (15.725,3.575);
\draw [indigo,thick] (14.825,2) -- (14.6417,1.67917);
\draw [indigo,thick,<->] (14.6417,1.67917) -- (14.4583,1.3583);
\draw [indigo,thick] (14.4583,1.3583) -- (14.275,1.0375) -- (0,1.0375);
\draw [indigo,thick,<->] (13,1.0375) -- (13.5,1.0375);
\draw [indigo,thick,<->] (4,1.0375) -- (8,1.0375);

%Angles
\draw [dashed] (14.275,1.0375) -- (13.825,1.7875);
\draw (14.125,1.2825) arc  (120:60:8pt);
\draw (14.125,1.2825) arc  (120:180:8pt);
