\begin{tikzpicture} [xscale=5,yscale=3]
		\def \N {4}%nombre de fentes
		\def \NN {8}%nombre de fentes
		\def \al {4}%a/lambda
		% legende
		\foreach \x in {2,4,6}{
			\draw[shift={({pi*asin((\x/2)/\al)/180},0)}] (0pt,1pt) -- (0pt,-1pt) node[below] {\scriptsize $\frac{\x\pi}{N}$};
			}
		%graphe
		\draw [blue,domain=0.001:1.1,samples=300] plot (\x,{(sin(pi*\N*\al*sin(\x r) r)/(\N*sin(pi*\al*sin(\x r) r)))^2});
		\draw[axis,->,>=latex] (0,0) -- (1.2,0) node[black,right] {\footnotesize $\varphi$};
		\draw[axis,->,>=latex] (0,0) -- (0,1.2) node[above,black] {\footnotesize $I$};
		\draw[shift={({pi*asin(1/\al)/180},.1)},|-|] ({-1/(\N*(\al*\al-1)^.5)},0)--({1/(\N*sqrt(\al*\al-1))},0)node[midway,above,fill=white]{\footnotesize $\delta\varphi$};
		%\draw (0.6,1.2)node{\footnotesize $N=\N$};
\end{tikzpicture}	{scope}[shift={(1.5,0)}]
