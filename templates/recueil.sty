% REDEFINE exo command
\RenewDocumentEnvironment{exo}{O{PC} O{1} O{colle} m}
{
\setcounter{equation}{0}
\setcounter{quest}{0}
\setcounter{subsection}{0}
\setcounter{subsubsection}{0}
\def\diff{
$\star$\ifnum#2=1\else
$\star$\ifnum#2=2\else
$\star$\ifnum#2=3\fi\fi\fi}
% counter redefinition
\ifthenelse{\equal{\detokenize{#3}}{\detokenize{appli}}}
	{
	% \setcounter{nombreExercices}{0}
	\initializeCounterForCalcul
	\hauteurLargeurCadreReponse		{8mm}{3cm}
	\dureeResolutionFacultative		{2} % 1, 2, 3 ou 4
	\typeEntrainement				{Newton} % Newton ou QCM ou AN ou vide (exercice "normal")
	\basiqueEtTransversal			{Y}
	\nombreColonnesQuestions		{1} % vide, 1, 2, 3, etc.
	\avecPlusieursQuestions			{Y} % Y ou N
	\renewcommand{\ExerciseName}{{
	% \normalsize
	% \includegraphics[height=10pt]{Bulldozer.pdf}
	% \faPenSquare
	\faPencil*
	}
	% \large 
	Ex.}
	\begin{Exercise}[title={#4}, exam={#4}, origin={\diff~}, label=appli, type={\textsc{#1}}]
	\vspace{-0.5cm}
	\begin{adjustwidth}{0.01cm}{0cm}
	% \indent
	}{
		\ifthenelse{\equal{\detokenize{#3}}{\detokenize{python}}}
		{
		\renewcommand{\ExerciseName}{{\normalsize \faPython}~\large Ex.}
		\begin{Exercise}[title={#4}, exam={#4}, origin={\diff~}, label=TD, type={\textsc{#1}}]
		}
		{
		\begin{Exercise}[title={#4}, exam={#4}, origin={\diff~}, label=#3, type={\textsc{#1}}]
		}
	}
}{
\ifthenelse{\equal{\detokenize{#3}}{\detokenize{appli}}}
{
\end{adjustwidth}
\end{Exercise}
}
{\end{Exercise}}
}

